# Caminhos essenciais do SODA (UV e Cargo)
SODA_UV_PATH=C:\Users\rosas\AppData\Roaming\uv\tools
SODA_CARGO_PATH=C:\Users\rosas\.cargo\bin

# 1. GITHUB
GITHUB_PAT="ghp_KEY"

# 2. GOOGLE AI STUDIO (Gemini CLI / MCPs Nativos)
GOOGLE_API_KEY="KEY"
# Usamos o flash-lite-preview para velocidade máxima e O(1) em ferramentas de leitura [5]
GOOGLE_MODEL_FAST="gemini-3.1-flash-lite-preview"
