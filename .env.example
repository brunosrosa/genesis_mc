# =========================================================
# SODA DEV ENVIRONMENT - SECURE KEYS & MODELS & VARIABLES
# =========================================================

# Caminhos essenciais do SODA (UV e Cargo)
SODA_UV_PATH=C:\Users\YOUR_USER\AppData\Roaming\uv\tools
SODA_CARGO_PATH=C:\Users\YOUR_USER\.cargo\bin

# 1. GITHUB
GITHUB_PAT="ghp_KEY"

# 2. OPENROUTER (Fallback e Automação Web)
OPENAI_API_FREE_KEY="sk-or-v1-KEY"
OPENROUTER_API_FAST="sk-or-v1-KEY"
OPENROUTER_API_HEAVY="sk-or-v1-KEY"
OPENAI_BASE_URL="https://openrouter.ai/api/v1"
# Roteamento inteligente nativo da plataforma para modelos de custo zero
OPENROUTER_DEFAULT_MODEL="openrouter/free"
# FASE 1: Leitura bruta e ingestão de contexto O(1)
OPENROUTER_FAST_MODEL="moonshotai/kimi-k2.5" 
# FASE 3: Formatador de JSON Strict (Âncora de baixo custo)
OPENROUTER_FORMATTER_MODEL="deepseek/deepseek-chat" 
# FASE 2: Enxame Cognitivo (As 3 Lentes SODA)
OPENROUTER_HEAVY_MODEL_LENS_UX="anthropic/claude-opus-4.7"
OPENROUTER_HEAVY_MODEL_LENS_ARQ="deepseek/deepseek-v4-pro"
OPENROUTER_HEAVY_MODEL_LENS_OPS="zhipuai/glm-5"

# 3. GOOGLE AI STUDIO (Gemini CLI / MCPs Nativos)
GOOGLE_API_KEY="G-KEY"
# Usamos o flash-lite-preview para velocidade máxima e O(1) em ferramentas de leitura [5]
GOOGLE_MODEL_FAST="gemini-flash-latest"
# Alias dinâmico para garantir sempre a versão Pro mais avançada no orquestrador
GOOGLE_MODEL_PRO="gemini-pro-latest"

# 4. FIRECRAW
FIRECRAWL_API_KEY="fc-KEY"

# 5. GOOGLE SERVICE ACCOUNT (mcp-google-sheets)
GOOGLE_APPLICATION_CREDENTIALS="C:\Users\YOUR_USER\.keys\soda-sheets-service-account.json"